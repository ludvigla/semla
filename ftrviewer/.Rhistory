#' <Add Title>
#'
#' <Add Description>
#'
#' @import htmlwidgets
#'
#' @export
ftrviewer <- function (
host = "127.0.0.1",
port = "8080",
width = "800px",
height = "800px",
elementId = NULL
) {
host <- "127.0.0.1"
port <- "8080"
width <- height <- 800
sampleID <- 1
# describe a React component to send to the browser for rendering.
content <- reactR::component(
"Ftrviewer"#,
#list(port = port, host = host, width = width, height = height, sampleID,
#     levels = NULL, colors = RColorBrewer::brewer.pal(n = 9, name = "Spectral") |> rev(), scaleByOpacity = FALSE, categories = NULL)
)
component <- reactR::reactMarkup(content)
# create widget
htmlwidgets::createWidget(
name = 'ftrviewer',
component,
width = width,
height = height,
package = 'ftrviewer',
elementId = elementId
)
}
